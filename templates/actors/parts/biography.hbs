<div class="biography body">

  {{!-- Memory Fragments --}}
  <ul class="memories">
    <li>
      <div class="memory header flexcol" data-type="memory">
        <div class="label flexrow">
          <h4>{{localize "NECH.FragmentsOfMemory"}}</h4>
          <div class="item-controls">
            <a class="item-control item-add" title="{{localize "NECH.AddItem"}}" data-type="memory"><i class="fas fa-plus"></i></a>
          </div>
        </div>
        <div class="details flexrow">
          <div class="name">{{localize "NECH.Title"}}</div>
          <div class="number">{{localize "NECH.Number"}}</div>
          <div class="effect">{{localize "NECH.ContentOfMemory"}}</div>
          <div class="item-controls">
          </div>
        </div>
      </div>

      <ul class="memory-list item-list">
        {{#each memories as |memory|}}
          <li class="memory item details flexrow" data-item-id="{{memory._id}}">
            {{!-- <div class="rollable" style="background-image: url({{memory.img}})" title="{{memory.name}}" width="24" height="24"></div> --}}
            <div class="name"><h4>{{memory.name}}</h4></div>
            <div class="number">{{memory.system.number}}</div>
            <div class="content">{{{memory.system.description}}}</div>
            {{#if ../isOwner}}
              <div class="item-controls">
                <a class="item-control item-edit" title="{{localize "NECH.EditItem"}}"><i class="fas fa-edit"></i></a>
                <a class="item-control item-duplicate" title="{{localize "NECH.DuplicateItem"}}"><i class="fas fa-copy"></i></a>
                <a class="item-control item-delete" title="{{localize "NECH.DeleteItem"}}"><i class="fas fa-trash"></i></a>
              </div>
            {{/if}}
          </li>
        {{/each}}
      </ul>

    </li>
  </ul>

  {{!-- Regrets --}}

  <ul class="regrets">
    <li>
      <div class="regret header flexcol" data-type="regret">
        <div class="label flexrow">
          <h4>{{localize "NECH.Regrets"}}</h4>
          <div class="item-controls">
            <a class="item-control item-add" title="{{localize "NECH.AddItem"}}" data-type="regret"><i class="fas fa-plus"></i></a>
          </div>
        </div>
        <div class="details flexrow">
          <div class="target">{{localize "NECH.Target"}}</div>
          <div class="type">{{localize "NECH.Type"}}</div>
          <div class="madness">{{localize "NECH.Madness"}}</div>
          <div class="effect">{{localize "NECH.Effect"}}</div>
          <div class="item-controls">
          </div>
        </div>
      </div>

      <ul class="regret-list item-list">
        {{#each regrets as |regret|}}
          <li class="regret item details flexrow" data-item-id="{{regret._id}}">
            {{!-- <div class="rollable" style="background-image: url({{regret.img}})" title="{{ .name}}" width="24" height="24"></div> --}}
            <div class="target"><h4>{{regret.system.target}}</h4></div>
            {{!--<input class="target item-quick-edit" data-target="system.target" value="{{regret.system.target}}">--}}
            <div class="type">{{regret.system.content}}</div>
            <div class="circle-position madness">
              <div class="circle-row" data-target="item" data-item-target="system.madness">
                {{#each regret.circles as |circle index|}}
                  {{#if circle.filled}}
                    <a class="circles" data-index={{index}}>
                      <div class="circle black"></div>
                    </a>
                  {{else}}
                    <a class="circles" data-index={{index}}>
                      <div class="circle"></div>
                    </a>
                  {{/if}}
                {{/each}}
              </div>
            </div>

            <div class="content">{{{regret.system.effect}}}</div>
            {{#if ../isOwner}}
              <div class="item-controls">
                <a class="item-control item-edit" title="{{localize "NECH.EditItem"}}"><i class="fas fa-edit"></i></a>
                <a class="item-control item-duplicate" title="{{localize "NECH.DuplicateItem"}}"><i class="fas fa-copy"></i></a>
                <a class="item-control item-delete" title="{{localize "NECH.DeleteItem"}}"><i class="fas fa-trash"></i></a>
              </div>
            {{/if}}
          </li>
        {{/each}}
      </ul>

    </li>
  </ul>

  <hr>
  {{!-- Biography Editor --}}
  {{editor system.details.biography target="system.details.biography" rollData=rollData button=true owner=owner editable=editable}}
</div>

